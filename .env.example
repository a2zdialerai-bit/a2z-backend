# ============================================================
# A2Z DIALER — FULL .ENV (GOOGLE CAL + CALENDLY + 2 VOICE MODES)
# ============================================================

# ----------------------------
# SERVER / APP
# ----------------------------
ENV=local
BASE_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=sqlite:///database.db

# Optional CORS override
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ----------------------------
# AUTH / JWT
# ----------------------------
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_64+_CHARS
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ----------------------------
# TWILIO (REQUIRED FOR CALLING)
# ----------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Voice / speech fallback for Gather mode
TWILIO_TTS_VOICE=Polly.Joanna
TWILIO_TTS_LANGUAGE=en-US
TWILIO_GATHER_TIMEOUT=6
TWILIO_SPEECH_TIMEOUT=auto
TWILIO_SPEECH_MODEL=phone_call
TWILIO_ENHANCED_SPEECH=true
TWILIO_GATHER_BARGE_IN=true

# SMS confirmations
ENABLE_SMS_CONFIRMATION=true
TWILIO_SMS_FROM_NUMBER=+1XXXXXXXXXX

# ----------------------------
# COMPLIANCE / WINDOWS / DNC
# ----------------------------
DEFAULT_TIMEZONE=America/New_York
CALL_WINDOW_START=09:00
CALL_WINDOW_END=19:00
CALL_DAYS=Mon,Tue,Wed,Thu,Fri,Sat
GLOBAL_DNC_ENABLED=false

# ----------------------------
# PATHWAY / SCRIPT SETTINGS
# ----------------------------
SCRIPT_STRICT_MODE=false
MIN_SPEECH_ALNUM=3
MIN_SPEECH_CONFIDENCE=0.30

# ----------------------------
# OPENAI — PHRASING ONLY / GENERAL API
# ----------------------------
OPENAI_PHRASING_ENABLED=true
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REWRITE_CACHE_MAX=800

# ----------------------------
# TWO VOICE PIPELINES
# ----------------------------
# realtime = OpenAI Realtime
# clone    = ElevenLabs/clone pipeline
VOICE_MODE_DEFAULT=realtime

# --- OpenAI Realtime ---
OPENAI_REALTIME_ENABLED=true
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_TEMPERATURE=0.4

# --- Voice clone pipeline ---
VOICE_CLONE_ENABLED=true
VOICE_CLONE_PROVIDER=elevenlabs

ELEVENLABS_API_KEY=el_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# STT for clone pipeline
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=dg_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# APPOINTMENTS — GOOGLE + CALENDLY
# ----------------------------
APPOINTMENT_MODE_DEFAULT=google

# ---- GOOGLE CALENDAR ----
GOOGLE_CALENDAR_ENABLED=true
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/integrations/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar.events

# ---- CALENDLY ----
CALENDLY_ENABLED=true
CALENDLY_LINK_DEFAULT=https://calendly.com/YOUR_HANDLE/15min
CALENDLY_PERSONAL_ACCESS_TOKEN=cal_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CALENDLY_WEBHOOK_SIGNING_KEY=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# EMAIL
# ----------------------------
EMAIL_ENABLED=false
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=appointments@a2zdialer.com

# ----------------------------
# BILLING / STRIPE
# ----------------------------
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# WORKER / AUTOPILOT
# ----------------------------
AUTOPILOT_ENABLED=true
AUTOPILOT_TICK_SECONDS=10
AUTOPILOT_LIMIT_PER_CAMPAIGN=3
WORKER_MAX_CONCURRENCY=5

# ----------------------------
# DEPLOY / LOGGING
# ----------------------------
LOG_LEVEL=info