ACCESS_TOKEN_EXPIRE_MINUTES=43200


# ----------------------------
# COMPLIANCE / WINDOWS / DNC
# ----------------------------
DEFAULT_TIMEZONE=America/New_York
CALL_WINDOW_START=09:00
CALL_WINDOW_END=19:00
CALL_DAYS=Mon,Tue,Wed,Thu,Fri,Sat
GLOBAL_DNC_ENABLED=false

# ----------------------------
# PATHWAY / SCRIPT SETTINGS
# ----------------------------
SCRIPT_STRICT_MODE=false
MIN_SPEECH_ALNUM=3
MIN_SPEECH_CONFIDENCE=0.30

# ----------------------------
# OPENAI — PHRASING ONLY / GENERAL API
